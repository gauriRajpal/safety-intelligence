# Copy to .env and fill in. All are OPTIONAL — the API runs with none of them
# set (SQLite, in-memory buffers, template advisor, no graph).

# Generative advisor — set to enable live LLM advisories (else template fallback)
ANTHROPIC_API_KEY=
ADVISOR_MODEL=claude-sonnet-4-6

# Persistence (defaults to local SQLite if unset)
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinel
REDIS_URL=redis://localhost:6379/0

# Knowledge graph (graph boost = 0 if unset)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sentinelpass

# Frontend origins allowed by CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
